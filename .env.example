# Frontend API base URL.
# Local dev can leave this empty because Vite/Express use the same origin.
# iOS/Android packaged apps MUST set this to your HTTPS server, for example:
# VITE_API_BASE_URL="https://api.your-domain.com"
VITE_API_BASE_URL=

# Recommended free/fast provider: Groq. Create the key in Groq Console.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini AI API key. Optional if Groq/OpenAI-compatible config is configured.
GEMINI_API_KEY=
GEMINI_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.5-flash

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# OpenAI-compatible configuration.
# This can point to your own server or any OpenAI-compatible provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_MODELS=
AI_TIMEOUT_MS=45000
AI_MAX_TOKENS=1200
AI_THINKING=disabled

# PostgreSQL progress storage. Leave empty to disable server-side progress storage.
DATABASE_URL=
# Or configure with PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE.
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_MAX=5
