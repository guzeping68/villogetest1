    {
      "type": "narrator",
      "speaker": "旁白",
      "avatar": "/assets/NPC.png",
      "text": "Mrs. Henderson准备走了。",
      "text_cn": "（Mrs. Henderson准备走了。）"
    },
    {
      "type": "dialogue",
      "speaker": "You",
      "avatar": "/assets/youhappy.png",
      "text": "Thank you, Jake.",
      "text_cn": ""
    },
    {
      "type": "dialogue",
      "speaker": "Jake",
      "avatar": "/assets/jackhappy.png",
      "text": "No problem.",
      "text_cn": ""
    },
    {
      "type": "dialogue",
      "speaker": "Mrs. Henderson",
      "avatar": "/assets/MrsHendersonhappy.png",
      "text": "If you need anything — knock on my door. 4A.",
      "text_cn": ""
    },
    {
      "type": "dialogue",
      "speaker": "Jake",
      "avatar": "/assets/jackhappy.png",
      "text": "Same. 5B.",
      "text_cn": ""
    },
    {
      "type": "question",
      "format": "multiple_choice",
      "instruction": "📍 题目5\nYou want to ask: who was in this apartment before you?",
      "options": [
        {
          "label": "A",
          "text": "Who lived here before me?",
          "is_correct": true
        },
        {
          "label": "B",
          "text": "after me",
          "is_correct": false
        }
      ]
    },
    {
      "type": "narrator",
      "speaker": "旁白",
      "avatar": "/assets/NPC.png",
      "text": "The hallway goes quiet. Your new apartment finally feels still. Later that night, you open a kitchen drawer and find a small note.",
      "text_cn": "（走廊重新安静下来。你的新公寓终于平静了。那天晚上晚些时候，你打开厨房抽屉，发现了一张小纸条。）"
    },
    {
      "type": "narrator",
      "speaker": "旁白",
      "avatar": "/assets/NPC.png",
      "text": "两人安静了一秒。",
      "text_cn": "（两人安静了一秒。）"
    },
    {
      "type": "narrator",
      "speaker": "旁白",
      "avatar": "/assets/NPC.png",
      "text": "他们离开。你打开厨房抽屉，看到一张便利贴：",
      "text_cn": "（他们离开。你打开厨房抽屉，看到一张便利贴：）"
    },
    {
      "type": "narrator",
      "speaker": "旁白",
      "avatar": "/assets/NPC.png",
      "text": "你把它放回去了。",
      "text_cn": "（你把它放回去了。）"
    },
    {
      "type": "dialogue",
      "speaker": "You",
      "avatar": "/assets/youhappy.png",
      "text": "Who lived here before me?",
      "text_cn": ""
    },
    {
      "type": "dialogue",
      "speaker": "Jake",
      "avatar": "/assets/jackhappy.png",
      "text": "Mrs. H's son. Ryan.",
      "text_cn": ""
    },
    {
      "type": "dialogue",
      "speaker": "Mrs. Henderson",
      "avatar": "/assets/MrsHendersonhappy.png",
      "text": "That's a story for another day, dear.",
