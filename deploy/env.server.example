# Domain pointing to this Tencent Cloud host, for example api.example.com.
API_DOMAIN=api.your-domain.com

# App backend.
NODE_ENV=production
PORT=3000

# AI provider: Zhipu BigModel through the OpenAI-compatible API.
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=your_bigmodel_key
OPENAI_MODEL=glm-4.7-flash
OPENAI_MODELS=glm-4.7-flash
AI_TIMEOUT_MS=45000
AI_MAX_TOKENS=1200
AI_THINKING=disabled

# PostgreSQL progress storage. On Railway, prefer:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_MAX=5
